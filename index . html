/* Dynamic Weather & Time Backgrounds */
.theme-morning { background: linear-gradient(to bottom, #ffafbd, #ffc3a0); color: #222; }
.theme-noon { background: linear-gradient(to bottom, #4ca1af, #c4e0e5); color: #111; }
.theme-evening { background: linear-gradient(to bottom, #e14fad, #f9d423); color: #fff; }
.theme-night { background: radial-gradient(circle at top right, #1a0b36, #05050c); color: #f3f4f6; }
.theme-rainy { background: linear-gradient(to bottom, #617ca5, #2a3a52); color: #eee; }

/* Rain Animation Effect */
.rain { position: absolute; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none; z-index: 1; display: none; }
.drop { position: absolute; background: linear-gradient(transparent, #ffffff); width: 1px; height: 50px; opacity: 0.7; animation: fall 1s linear infinite; }
@keyframes fall { 0% { transform: translateY(-50px); } 100% { transform: translateY(100vh); } }
</style>
