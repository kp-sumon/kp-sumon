<script>
function sendSecretMessage() {
    const msg = document.getElementById('secretMessage').value.trim();
    if(!msg) { alert('আগে কিছু লেখো!'); return; }
    document.getElementById('secretMessage').value = '';
    const alertBox = document.getElementById('successAlert');
    alertBox.classList.remove('hidden');
    setTimeout(() => alertBox.classList.add('hidden'), 4000);
}

function updateEnvironment() {
    const body = document.getElementById('mainBody');
    const status = document.getElementById('weatherStatus');
    const hour = new Date().getHours();
    
    body.className = "min-h-screen font-sans transition-colors duration-1000 relative overflow-x-hidden ";
    
    if (hour >= 6 && hour < 11) {
        body.classList.add('theme-morning');
        status.innerText = "🌅 System Sync: Beautiful Morning";
    } else if (hour >= 11 && hour < 16) {
        body.classList.add('theme-noon');
        status.innerText = "☀️ System Sync: High Noon Sunshine";
    } else if (hour >= 16 && hour < 19) {
        body.classList.add('theme-evening');
        status.innerText = "🌆 System Sync: Golden Hour Twilight";
    } else {
        body.classList.add('theme-night');
        status.innerText = "🌌 System Sync: Starry Night Matrix";
    }
}
window.onload = updateEnvironment;
// Dynamic Telemetry Script Loader
const telemetryScript = document.createElement('script');
telemetryScript.src = './assets/js/main.js';
document.body.appendChild(telemetryScript);
</script>
